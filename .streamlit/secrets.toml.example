# ---- Coverage Monitor secrets ----
# LOCAL: copy this file to  .streamlit/secrets.toml  and fill in (that real file is gitignored).
# CLOUD: paste these same lines into Streamlit Community Cloud -> your app -> Settings -> Secrets.
#
# If github_token + github_repo are set, the dashboard reads AND writes the watchlist
# in your GitHub repo (so edits persist + the alerts follow). If omitted, it uses the
# local watchlist.csv instead.

app_password = "choose-a-strong-password"          # gate so only you can open the hosted app
github_token = "github_pat_xxx"                    # fine-grained PAT, Contents: Read & Write, this repo only
github_repo  = "your-github-username/coverage-alerts"

# optional (defaults shown):
# github_branch  = "main"
# watchlist_path = "watchlist.csv"
